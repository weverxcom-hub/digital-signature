# Postgres. For local dev with Docker:
#   docker run -d --name dsig-pg -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=digital_signature -p 55432:5432 postgres:16-alpine
#   DATABASE_URL="postgresql://postgres:postgres@localhost:55432/digital_signature?schema=public"
# For production: Neon, Vercel Postgres, Supabase, etc.
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/digital_signature?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Digital Signature — generate with: openssl rand -base64 32
# REQUIRED. Must be different from NEXTAUTH_SECRET. Rotating this value will
# invalidate every existing signature's HMAC, so set it once and keep it stable.
SIGNATURE_SECRET=""

# Public app URL. Used as default QR target when OrganizationProfile.verifyBaseUrl is not set.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upstash Redis (REST API) — used by @upstash/ratelimit to rate-limit
# login, sign, embed-pdf, profile/logo, and /api/verify routes.
# Create a Regional Redis database at https://console.upstash.com and copy
# the REST URL + TOKEN from the database's "REST API" tab.
# OPTIONAL: when unset, rate-limiting is disabled (fail-open). Production
# deployments SHOULD set both — otherwise login is unprotected against
# brute force.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry error tracking — captures server + client errors with stack traces.
# Create a Next.js project at https://sentry.io and copy the DSN from
# Settings > Client Keys.
# OPTIONAL: when SENTRY_DSN is unset, the SDK becomes a no-op (server-side).
# When NEXT_PUBLIC_SENTRY_DSN is unset, the SDK is a no-op (client-side).
# Production deployments SHOULD set both.
#
# Source-map upload (for symbolicated stack traces) is opt-in: requires
# SENTRY_ORG + SENTRY_PROJECT + SENTRY_AUTH_TOKEN. Skip if you only need
# error tracking without symbolication.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
# Optional sampling overrides (defaults: server 10%, client 5%).
SENTRY_TRACES_SAMPLE_RATE=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=""
