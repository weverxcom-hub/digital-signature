# Database — for production use Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Digital Signature — generate with: openssl rand -base64 32
# Optional. Falls back to NEXTAUTH_SECRET if empty.
SIGNATURE_SECRET=""

# Public app URL. Used as default QR target when OrganizationProfile.verifyBaseUrl is not set.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
